# Roman Bath — environment variables
# Copy to .env in the repo root (Vite loads from parent of frontend/)

# ZeroClaw Gateway port (default 42617)
# Must match the port used by:
# cargo run --no-default-features --features gateway,agent-runtime -- gateway start -p <port>
VITE_ZEROCLAW_PORT=42617

# Optional product surfaces. Roman Bath defaults to a lean chat-only UI.
# Set individual flags to true only when you want those surfaces exposed.
VITE_ENABLE_IMAGE_GEN=false
VITE_ENABLE_TTS=false
VITE_ENABLE_VOICE_INPUT=false
VITE_ENABLE_GROUP_CHAT=false
VITE_ENABLE_STUDIO=false
VITE_ENABLE_AFFECT=false
VITE_ENABLE_BOOKMARKS=false

# LLM API keys are NOT configured here.
# Set model providers in ZeroClaw: ~/.zeroclaw/config.toml
