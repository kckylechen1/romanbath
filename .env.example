# Roman Bath — environment variables
# Copy to .env in the repo root (Vite loads from parent of frontend/)

# ZeroClaw Gateway port (default 42617)
# Must match the port used by: cargo run -- gateway start -p <port>
VITE_ZEROCLAW_PORT=42617

# LLM API keys are NOT configured here.
# Set model providers in ZeroClaw: ~/.zeroclaw/config.toml
